# Normalize all text files to LF line endings in the repository.
# On checkout, LF is used regardless of contributor OS.
* text=auto eol=lf

# Explicitly mark binary assets — never process line endings
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.webp   binary
*.ttf    binary
*.otf    binary
*.woff   binary
*.woff2  binary
