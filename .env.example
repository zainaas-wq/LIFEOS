# LifeOS — Environment variables
# Copy this file to .env and fill in your Supabase project values.
# .env is gitignored. Never commit real keys.

# Supabase project URL — found in: Supabase Dashboard → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon public key — found in: Supabase Dashboard → Settings → API
# This key is safe to include in client-side code (it is public by design).
# Row-Level Security policies enforce per-user data isolation server-side.
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
